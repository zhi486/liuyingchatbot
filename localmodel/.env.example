# 百度语音（语音识别）
BAIDU_APP_ID=your_app_id
BAIDU_API_KEY=your_api_key
BAIDU_SECRET_KEY=your_secret_key

# Fish Audio（语音合成）
FISH_API_KEY=your_fish_api_key
LIUYING_REFERENCE_ID=your_reference_id

# 代理（可选，用于访问外网 API）
PROXY_URL=http://127.0.0.1:7890

# 模型路径（可选，默认 localmodel/models/qwen/Qwen2-7B-Instruct）
# MODEL_PATH=

# ffmpeg 路径（可选，用于音频格式转换）
# FFMPEG_PATH=
